{
  "ietf-interfaces:interfaces": {
    "interface": [
      {
        "name": "eth0",
        "type": "iana-if-type:ethernetCsmacd",
        "ietf-ip:ipv4": {
          "czechlight-network:dhcp-client": false,
          "address": [
            {
              "ip": "192.0.2.1",
              "prefix-length": 24
            }
          ]
        }
      },
      {
        "name": "eth1",
        "type": "iana-if-type:ethernetCsmacd",
        "ietf-ip:ipv4": {
          "czechlight-network:dhcp-client": true
        }
      }
    ]
  },
  "ietf-netconf-server:netconf-server": {
    "listen": {
      "endpoints": {
        "endpoint": [
          {
            "name": "default-ssh",
            "ssh": {
              "tcp-server-parameters": {
                "local-bind": [
                  {
                    "local-address": "::"
                  }
                ]
              },
              "ssh-server-parameters": {
                "server-identity": {
                  "host-key": [
                    {
                      "name": "default-key",
                      "public-key": {
                        "central-keystore-reference": "genkey"
                      }
                    }
                  ]
                }
              }
            }
          },
          {
            "name": "unix",
            "libnetconf2-netconf-server:unix": {
              "hidden-path": [null],
              "socket-permissions": {
                "mode": "0666"
              }
            }
          }
        ]
      }
    }
  },
  "ietf-keystore:keystore": {
    "asymmetric-keys": {
      "asymmetric-key": [
        {
          "name": "genkey",
          "public-key-format": "ietf-crypto-types:ssh-public-key-format",
          "private-key-format": "ietf-crypto-types:rsa-private-key-format",
          "cleartext-private-key": ""
        }
      ]
    }
  },
  "czechlight-coherent-add-drop:client-ports": {
    "port": [
      {
        "port": 1,
        "add": {
          "critical-low": {
            "level": "-30.0"
          },
          "warning-low": {
            "level": "-15.0"
          },
          "warning-high": {
            "level": "3.0"
          },
          "critical-high": {
            "level": "5.0"
          }
        }
      },
      {
